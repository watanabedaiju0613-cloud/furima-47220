<script src="https://js.pay.jp/v2/pay.js"></script>

<div class="transaction-contents">
  <div class="transaction-main">
    <h1 class="page-headline">購入内容の確認</h1>

    <div class="buy-item-info">
      <div class="buy-item-img">
        <%= image_tag @item.image, class: "item-box-img" %>
      </div>
      <div class="buy-item-text">
        <p class="buy-item-name"><%= @item.name %></p>
        <p class="buy-item-price">¥ <%= @item.price %> (税込)<br><%= @item.shipping_fee_status.name %></p>
      </div>
    </div>

    <div class="purchase-price-box">
      <span class="purchase-price-text">支払金額</span>
      <span class="purchase-price">¥ <%= @item.price %></span>
    </div>

    <%= form_with model: @order_address, url: item_orders_path(@item.id), local: true, id: "charge-form", data: { turbo: false, payjp_public_key: ENV["PAYJP_PUBLIC_KEY"] } do |f| %>
      <%= render 'shared/error_messages', model: f.object %>

      <div class="credit-card-form">
        <h2 class="credit-card-headline">クレジットカード情報入力</h2>
        <div class="input-content">
          <label>カード番号<span class="indispensable">必須</span></label>
          <div id="number-form" class="input-card-number"></div>
        </div>
        <div class="input-content">
          <label>有効期限<span class="indispensable">必須</span></label>
          <div id="expiry-form" class="input-expiration-date"></div>
        </div>
        <div class="input-content">
          <label>セキュリティコード<span class="indispensable">必須</span></label>
          <div id="cvc-form" class="input-security-code"></div>
        </div>
      </div>

      <div class="address-form">
        <h2 class="address-headline">配送先</h2>
        <div class="input-content">
          <label>郵便番号<span class="indispensable">必須</span></label>
          <%= f.text_field :postal_code, class: "input-default", placeholder: "例)123-4567（ハイフン必須）" %>
        </div>
        <div class="input-content">
          <label>都道府県<span class="indispensable">必須</span></label>
          <%= f.collection_select :prefecture_id, Prefecture.all, :id, :name, {}, { class: "select-box" } %>
        </div>
        <div class="input-content">
          <label>市区町村<span class="indispensable">必須</span></label>
          <%= f.text_field :city, class: "input-default", placeholder: "例)横浜市緑区" %>
        </div>
        <div class="input-content">
          <label>番地<span class="indispensable">必須</span></label>
          <%= f.text_field :house_number, class: "input-default", placeholder: "例)青山1-1-1" %>
        </div>
        <div class="input-content">
          <label>建物名</label>
          <%= f.text_field :building_name, class: "input-default", placeholder: "例)柳ビル103" %>
        </div>
        <div class="input-content">
          <label>電話番号<span class="indispensable">必須</span></label>
          <%= f.text_field :phone_number, class: "input-default", placeholder: "例)09012345678（ハイフン不要）" %>
        </div>
      </div>

      <div class="buy-btn-content">
        <%= f.submit "購入する", class: "buy-red-btn" %>
      </div>
    <% end %>
  </div>
</div>
